# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
# MongoDB connection URI (e.g., local instance or MongoDB Atlas cluster connection string)
MONGODB_URI=mongodb://127.0.0.1:27017/cicd_epic

# Security Configuration
# CORS Allowed Origin (set to '*' to allow all, or a specific domain in production)
CORS_ORIGIN=*

# JWT Authentication Config (Planned for later stage)
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRE=24h
